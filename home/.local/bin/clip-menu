#!/usr/bin/env bash
set -u
dir="$HOME/.cache/clip-history"
[ -d "$dir" ] || { notify-send "Clipboard" "History empty"; exit 0; }

# Paste the CURRENT clipboard into the focused window by sending the paste
# shortcut — NOT by typing the text out. Typing (wtype "text") replays every
# character, so embedded newlines become real Enter presses: in a chat/box the
# message fires mid-paste and the rest spills into the next line. Pasting from
# the clipboard is one atomic event, so any length / any newlines land intact.
# Terminals use Ctrl+Shift+V; everything else uses Ctrl+V — so detect the app.
paste_clipboard() {
  sleep 0.15                      # let focus return to the app rofi covered
  local app=""
  if command -v jq >/dev/null 2>&1 && command -v swaymsg >/dev/null 2>&1; then
    app=$(swaymsg -t get_tree 2>/dev/null \
          | jq -r 'recurse(.nodes[]?, .floating_nodes[]?)
                   | select(.focused==true)
                   | (.app_id // .window_properties.class // "")' 2>/dev/null | head -n1)
  fi
  case "${app,,}" in
    foot|footclient|foot-server|alacritty|kitty|wezterm|org.wezfurlong.wezterm|\
    konsole|org.kde.konsole|xterm|st|urxvt|rxvt*|termite|tilix|terminator|\
    contour|xfce4-terminal|*-terminal|*terminal*|*term)
      wtype -M ctrl -M shift -k v -m shift -m ctrl ;;   # Ctrl+Shift+V
    *)
      wtype -M ctrl -k v -m ctrl ;;                     # Ctrl+V
  esac
}

list=$(for f in $(ls -1t "$dir" 2>/dev/null); do
  case "$f" in
    img_*) prev="[ Screenshot / image ]   $(date -r "$dir/$f" +%H:%M)" ;;
    txt_*) prev="$(tr '\n\t' '  ' < "$dir/$f" | sed 's/  */ /g' | cut -c1-120)" ;;
    *) continue ;;
  esac
  printf '%s\t%s\n' "$f" "$prev"
done)
[ -z "$list" ] && { notify-send "Clipboard" "History empty"; exit 0; }

sel=$(printf '%s\n' "$list" | rofi -dmenu -i -display-columns 2 -p "Clipboard" \
        -theme ~/.config/rofi/clipboard.rasi \
        -mesg "Enter paste  ·  Alt+Enter copy only  ·  Alt+Delete clear history" \
        -kb-custom-1 "Alt+Return" -kb-custom-2 "Alt+Delete")
rc=$?
[ "$rc" -eq 11 ] && { rm -f "$dir"/*; notify-send "Clipboard" "History cleared"; exit 0; }
[ -z "${sel:-}" ] && exit 0
f=$(printf '%s' "$sel" | cut -f1)
[ -f "$dir/$f" ] || exit 0

case "$f" in
  img_*)
    wl-copy --type image/png < "$dir/$f" >/dev/null 2>&1
    notify-send "Clipboard" "Image copied — paste with Ctrl+V"
    ;;
  txt_*)
    wl-copy < "$dir/$f" >/dev/null 2>&1
    if [ "$rc" -eq 10 ]; then exit 0; fi     # Alt+Enter = copy only, no paste
    paste_clipboard
    ;;
esac
