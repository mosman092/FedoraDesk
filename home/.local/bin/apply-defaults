#!/usr/bin/env bash
# Applies ~/.config/default-apps.conf system-wide: MIME defaults, keybindings, env
set -u
conf="$HOME/.config/default-apps.conf"
[ -f "$conf" ] || { echo "missing $conf"; exit 1; }

declare -A MIMES=(
[browser]="x-scheme-handler/http x-scheme-handler/https text/html application/xhtml+xml x-scheme-handler/about x-scheme-handler/unknown"
[mail_client]="x-scheme-handler/mailto message/rfc822 application/mbox"
[calendar]="text/calendar x-scheme-handler/webcal x-scheme-handler/webcals"
[contacts]="text/vcard"
[file_manager]="inode/directory x-scheme-handler/trash x-scheme-handler/recent x-scheme-handler/computer x-scheme-handler/network"
[text_editor]="text/plain text/x-readme text/x-log text/x-changelog text/x-patch text/x-rst text/x-bibtex text/x-gettext-translation text/troff"
[code_editor]="text/x-python text/x-python3 text/x-csrc text/x-chdr text/x-c++src text/x-c++hdr text/x-java text/x-csharp text/x-go text/rust text/x-lua application/x-perl application/x-php application/x-ruby application/x-shellscript text/css text/javascript application/sql application/toml text/x-makefile text/x-cmake text/x-meson"
[image_viewer]="image/jpeg image/png image/gif image/webp image/bmp image/tiff image/svg+xml image/svg+xml-compressed image/apng image/heif image/avif image/jxl image/jp2 image/vnd.microsoft.icon image/x-icns image/x-tga image/x-portable-pixmap image/x-portable-bitmap image/x-portable-graymap image/x-portable-anymap image/x-xpixmap image/x-xbitmap image/x-sgi image/x-sun-raster image/x-dds image/x-exr image/x-ilbm image/x-pict image/x-rgb image/x-xwindowdump image/vnd.wap.wbmp image/vnd.adobe.photoshop image/x-xcf image/openraster image/vnd.djvu image/vnd.djvu+multipage image/ktx image/ktx2 image/x-adobe-dng image/x-canon-cr2 image/x-canon-cr3 image/x-nikon-nef image/x-olympus-orf image/x-panasonic-rw2 image/x-sony-arw image/x-fuji-raf image/x-pentax-pef image/x-minolta-mrw image/x-kodak-dcr image/x-sigma-x3f"
[image_editor]="image/x-xcf image/vnd.adobe.photoshop image/openraster application/x-krita"
[video_player]="video/mp4 video/x-matroska video/x-matroska-3d video/webm video/quicktime video/vnd.avi video/mpeg video/x-ms-wmv video/x-flv video/3gpp video/3gpp2 video/ogg video/x-theora+ogg video/x-ogm+ogg video/mp2t video/mj2 video/annodex video/x-flic video/x-mjpeg video/x-mng video/x-sgi-movie video/dv video/vnd.mpegurl video/vnd.rn-realvideo"
[audio_player]="audio/mpeg audio/mp4 audio/x-m4b audio/aac audio/x-ms-wma audio/ogg audio/x-vorbis+ogg audio/x-opus+ogg audio/x-flac+ogg audio/x-speex+ogg audio/flac audio/vnd.wave audio/x-wavpack audio/x-ape audio/x-tta audio/x-musepack audio/x-mod audio/x-s3m audio/x-xm audio/x-it audio/basic audio/x-aiff audio/amr audio/amr-wb audio/midi audio/x-gsm audio/x-voc audio/x-dsf audio/x-dff audio/webm audio/x-matroska audio/ac3 audio/mp2 audio/vnd.dts audio/vnd.dts.hd audio/prs.sid audio/x-scpls audio/x-mpegurl audio/x-ms-asx application/vnd.apple.mpegurl"
[pdf_viewer]="application/pdf"
[ebook_reader]="application/epub+zip application/x-mobipocket-ebook application/vnd.amazon.mobi8-ebook application/vnd.amazon.ebook application/x-fictionbook+xml application/vnd.comicbook+zip application/vnd.comicbook-rar application/x-cb7 application/x-cbt image/vnd.djvu image/vnd.djvu+multipage"
[word_processor]="application/msword application/vnd.openxmlformats-officedocument.wordprocessingml.document application/vnd.oasis.opendocument.text application/rtf application/vnd.openxmlformats-officedocument.wordprocessingml.template application/vnd.oasis.opendocument.text-template"
[spreadsheet]="application/vnd.ms-excel application/vnd.openxmlformats-officedocument.spreadsheetml.sheet application/vnd.oasis.opendocument.spreadsheet text/csv text/tab-separated-values application/vnd.openxmlformats-officedocument.spreadsheetml.template application/vnd.oasis.opendocument.spreadsheet-template"
[presentation]="application/vnd.ms-powerpoint application/vnd.openxmlformats-officedocument.presentationml.presentation application/vnd.oasis.opendocument.presentation application/vnd.openxmlformats-officedocument.presentationml.template application/vnd.oasis.opendocument.presentation-template"
[archive_manager]="application/zip application/x-tar application/gzip application/x-bzip2 application/x-xz application/zstd application/x-7z-compressed application/vnd.rar application/java-archive application/x-compressed-tar application/x-bzip2-compressed-tar application/x-xz-compressed-tar application/x-zstd-compressed-tar application/x-lzma application/x-lzip application/x-lha application/x-arj application/vnd.ms-cab-compressed application/x-cpio application/x-compress"
[torrent_client]="application/x-bittorrent x-scheme-handler/magnet"
[markdown_viewer]="text/markdown"
[json_viewer]="application/json application/ld+json application/geo+json"
[xml_viewer]="application/xml application/xml-dtd application/rss+xml application/atom+xml"
[yaml_viewer]="application/yaml"
[font_viewer]="font/ttf font/otf font/woff font/woff2 font/collection"
[messaging]="x-scheme-handler/irc x-scheme-handler/ircs x-scheme-handler/xmpp x-scheme-handler/sip x-scheme-handler/matrix"
[telephony]="x-scheme-handler/tel x-scheme-handler/sms x-scheme-handler/smsto"
[remote_desktop]="x-scheme-handler/rdp x-scheme-handler/vnc x-scheme-handler/spice x-scheme-handler/ssh"
[feed_reader]="x-scheme-handler/feed text/x-opml+xml"
)

get() { sed -n "s/^$1=//p" "$conf" | head -1 | tr -d ' '; }

resolve() {
  local name="$1" d f
  [ -z "$name" ] && return 1
  case "$name" in *.desktop) echo "$name"; return 0;; esac
  for d in "${APPDIRS[@]}"; do
    [ -f "$d/$name.desktop" ] && { echo "$name.desktop"; return 0; }
  done
  f=$(ls "${APPDIRS[@]}" 2>/dev/null \
      | grep -i -- "$name" | awk '{print length, $0}' | sort -n | head -1 | cut -d' ' -f2-)
  [ -n "$f" ] && { echo "$f"; return 0; }
  return 1
}

# .desktop search path — includes Flatpak exports (user + system)
APPDIRS=(
  "$HOME/.local/share/applications"
  "$HOME/.local/share/flatpak/exports/share/applications"
  /var/lib/flatpak/exports/share/applications
  /usr/share/applications
)

# launch_cmd <config-name> -> the shell command that launches it.
# Flatpak apps become "flatpak run <appid>"; everything else stays as-is.
launch_cmd() {
  local name="$1" desk appid
  [ -z "$name" ] && return 0
  desk="$(resolve "$name")" || { echo "$name"; return 0; }
  appid="${desk%.desktop}"
  if command -v flatpak >/dev/null && flatpak info "$appid" >/dev/null 2>&1; then
    echo "flatpak run $appid"
  else
    echo "$name"
  fi
}

# true if a resolved .desktop declares Terminal=true (can't launch from a GUI file
# manager on Sway — there is no x-terminal-emulator to host it)
is_terminal_desktop() {
  local d
  for d in "${APPDIRS[@]}"; do
    [ -f "$d/$1" ] && { grep -qiE '^Terminal[[:space:]]*=[[:space:]]*true' "$d/$1"; return; }
  done
  return 1
}

# CLI editor (nvim/vim/nano/helix/…): wrap it in a Terminal=false .desktop that runs
# it inside the terminal, so file managers / xdg-open can actually launch it.
# One wrapper per command (<cmd>-terminal.desktop) so text_editor and code_editor
# never clobber each other.
term_wrapper_desktop() {
  local ed="$1" t base; t=$(get terminal); t=${t:-foot}
  command -v "$ed" >/dev/null || return 1
  base="${ed}-terminal"
  mkdir -p ~/.local/share/applications
  printf '[Desktop Entry]\nType=Application\nName=%s (terminal)\nExec=%s -e %s %%F\nTerminal=false\nNoDisplay=true\nMimeType=text/plain;\nIcon=text-x-generic\n' \
    "$ed" "$t" "$ed" > ~/.local/share/applications/"$base".desktop
  echo "$base.desktop"
}

echo "MIME defaults:"
for cat in "${!MIMES[@]}"; do
  app=$(get "$cat"); [ -z "$app" ] && continue
  desk=$(resolve "$app")
  # editors: if the app is a terminal program (no .desktop, or Terminal=true),
  # substitute a Terminal=false wrapper so GUI launches actually work.
  if [ "$cat" = "text_editor" ] || [ "$cat" = "code_editor" ]; then
    if [ -z "${desk:-}" ] || is_terminal_desktop "$desk"; then
      w=$(term_wrapper_desktop "$app") && desk="$w"
    fi
  fi
  [ -z "${desk:-}" ] && { echo "  ! $cat=$app: no .desktop found"; continue; }
  # shellcheck disable=SC2086
  xdg-mime default "$desk" ${MIMES[$cat]} && echo "  $cat -> $app ($desk)"
done

browser=$(get browser)
[ -n "$browser" ] && xdg-settings set default-web-browser "$(resolve "$browser")" 2>/dev/null

term=$(get terminal); fm=$(get file_manager)
# terminal $EDITOR: prefer terminal_editor, fall back to text_editor
editor=$(get terminal_editor); [ -z "$editor" ] && editor=$(get text_editor)
# launch commands (Flatpak apps -> "flatpak run <id>")
term_cmd="$(launch_cmd "$term")"; browser_cmd="$(launch_cmd "$browser")"; fm_cmd="$(launch_cmd "$fm")"
swayfile="$HOME/.config/sway/config.d/default-apps.conf"
{
  echo "# Generated by apply-defaults — edit ~/.config/default-apps.conf instead"
  [ -n "$term" ]    && printf 'unbindsym $mod+Return\nbindsym $mod+Return exec %s\n' "$term_cmd"
  [ -n "$browser" ] && printf 'bindsym $mod+Shift+Return exec %s\n' "$browser_cmd"
  [ -n "$fm" ]      && printf 'bindsym $mod+Shift+f exec %s\n' "$fm_cmd"
} > "$swayfile"

envfile="$HOME/.config/sway/environment"
sed -i '/^TERMINAL=\|^BROWSER=\|^EDITOR=/d' "$envfile" 2>/dev/null
{ [ -n "$term" ] && echo "TERMINAL=$term_cmd"
  [ -n "$browser" ] && echo "BROWSER=$browser_cmd"
  [ -n "$editor" ] && echo "EDITOR=$editor"; } >> "$envfile"

swaymsg reload >/dev/null 2>&1 && echo "Sway reloaded."
command -v notify-send >/dev/null && notify-send "Default apps" "Applied from default-apps.conf"
echo "Done."
