#!/usr/bin/env bash
# Dark/light toggle covering GTK4 (portal, live), GTK3 (gsettings+ini), GTK2, Qt (portal, live)
#
# IMPORTANT: "Adwaita-dark" is NOT an installed theme on Fedora Sway — naming it in
# gtk-theme / gtk-theme-name makes GTK3 apps (Thunar) fail to find it and silently
# fall back to LIGHT. The only reliable dark for GTK3 here is the VALID built-in
# "Adwaita" theme + gtk-application-prefer-dark-theme=true. So gtk-theme is ALWAYS
# "Adwaita" and dark/light is driven purely by the prefer-dark flag + color-scheme.
set -u
mkdir -p ~/.config/gtk-3.0 ~/.config/gtk-4.0

if [ "$(gsettings get org.gnome.desktop.interface color-scheme)" = "'prefer-dark'" ]; then
  mode=light; scheme=prefer-light; dark=false
else
  mode=dark;  scheme=prefer-dark;  dark=true
fi

gsettings set org.gnome.desktop.interface color-scheme "$scheme"
gsettings set org.gnome.desktop.interface gtk-theme "Adwaita"   # valid name; dark via prefer-dark

for v in gtk-3.0 gtk-4.0; do
  printf '[Settings]\ngtk-theme-name=Adwaita\ngtk-application-prefer-dark-theme=%s\ngtk-icon-theme-name=Adwaita\n' \
    "$dark" > ~/.config/$v/settings.ini
done
printf 'gtk-theme-name="Adwaita"\n' > ~/.gtkrc-2.0

pkill -RTMIN+9 waybar 2>/dev/null          # refresh the waybar theme icon now
pgrep -x thunar >/dev/null && thunar -q 2>/dev/null
notify-send "Theme" "${mode^} mode enabled"
