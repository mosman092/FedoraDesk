#!/usr/bin/env bash
set -u
run="/run/user/$(id -u)"
busfile="$run/ext-brightness.bus"
tgt="$run/ext-brightness.target"
lock="$run/ext-brightness.lock"

case "${1:-}" in
  +*) brightnessctl -q set "${1#+}%+" ;;
  -*) brightnessctl -q set "${1#-}%-" ;;
  ?*) brightnessctl -q set "${1}%" ;;
esac
pct=$(( 100 * $(brightnessctl get) / $(brightnessctl max) ))
notify-send -h string:x-dunst-stack-tag:brightness -h int:value:"$pct" "Brightness" "${pct}%"

echo "$pct" > "$tgt"
(
  flock -n 9 || exit 0
  bus=$(cat "$busfile" 2>/dev/null)
  if [ -z "$bus" ] || ! ddcutil getvcp 10 --bus "$bus" >/dev/null 2>&1; then
    bus=$(ddcutil detect --brief 2>/dev/null | grep -oP '/dev/i2c-\K[0-9]+' | while read -r b; do
            ddcutil getvcp 10 --bus "$b" >/dev/null 2>&1 && { echo "$b"; break; }
          done)
    [ -n "$bus" ] && echo "$bus" > "$busfile"
  fi
  [ -z "$bus" ] && exit 0
  while :; do
    want=$(cat "$tgt")
    ddcutil setvcp 10 "$want" --bus "$bus" >/dev/null 2>&1
    [ "$want" = "$(cat "$tgt")" ] && break
  done
) 9>"$lock" &
disown
