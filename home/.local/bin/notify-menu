#!/usr/bin/env bash
# dunst notification-action menu (rofi, centered). dunst pipes lines like
# "#Confirm (Bluetooth) [12,confirm]"; show a clean label but return the
# original line unchanged so dunst still fires the right action.
mapfile -t orig
((${#orig[@]})) || exit 0
disp=()
for l in "${orig[@]}"; do c="${l#\#}"; disp+=("${c% \[*\]}"); done
idx=$(printf '%s\n' "${disp[@]}" | rofi -dmenu -i -format i -p "Action" -theme ~/.config/rofi/notify.rasi)
[ -n "$idx" ] && printf '%s\n' "${orig[$idx]}"
