#!/usr/bin/env bash
set -u

block='// Urdu Nastaliq for Arabic-script fallback (added by dotfiles)
user_pref("font.name-list.serif.ar",      "Noto Nastaliq Urdu, Noto Naskh Arabic");
user_pref("font.name-list.sans-serif.ar", "Noto Nastaliq Urdu, Noto Sans Arabic");
user_pref("font.name-list.monospace.ar",  "Noto Nastaliq Urdu, Noto Sans Mono");'

found=0
for base in "$HOME/.config/mozilla/firefox" "$HOME/.mozilla/firefox" \
            "$HOME/.var/app/org.mozilla.firefox/.mozilla/firefox"; do
  [ -d "$base" ] || continue
  for prof in "$base"/*/; do
    [ -d "$prof" ] || continue
    if [ ! -f "${prof}prefs.js" ] && [ ! -f "${prof}times.json" ]; then
      case "$prof" in *.default*/) : ;; *) continue ;; esac
    fi
    ujs="${prof}user.js"
    if grep -q "font.name-list.sans-serif.ar" "$ujs" 2>/dev/null; then
      found=1; continue
    fi
    printf '%s\n' "$block" >> "$ujs"
    echo "  Firefox Urdu pref written -> ${prof}user.js"
    found=1
  done
done

if [ "$found" -eq 0 ]; then
  echo "  No Firefox profile found yet — launch Firefox once, then run: apply-firefox-urdu"
fi
