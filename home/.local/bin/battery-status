#!/usr/bin/env bash
set -u
bat=/sys/class/power_supply/BAT0
r(){ cat "$bat/$1" 2>/dev/null; }

cap=$(r capacity); cap=${cap:-0}
status=$(r status)
cf=$(r charge_full); cfd=$(r charge_full_design); cyc=$(r cycle_count)
health="?"; if [ -n "$cf" ] && [ -n "$cfd" ] && [ "${cfd:-0}" -gt 0 ] 2>/dev/null; then health=$(( 100*cf/cfd )); fi

tp=$(cat /etc/tuned/active_profile 2>/dev/null)
case "$tp" in
  powersave)              prof="Power Saver";;
  balanced|balanced-*)    prof="Balanced";;
  *performance*)          prof="Performance";;
  "")                     prof="?";;
  *)                      prof="$tp";;
esac

# Font Awesome glyphs (generated at runtime so editors can't strip them)
bolt=$(printf '’ā¦'); plug=$(printf '’ć”')
i100=$(printf '’ēĆ'); i75=$(printf '’ēü'); i50=$(printf '’ēé'); i25=$(printf '’ēā'); i0=$(printf '’ēä')
case "$status" in
  Charging)            icon=$bolt ;;
  Full|"Not charging") icon=$plug ;;
  *) if   [ "$cap" -ge 90 ]; then icon=$i100
     elif [ "$cap" -ge 65 ]; then icon=$i75
     elif [ "$cap" -ge 40 ]; then icon=$i50
     elif [ "$cap" -ge 15 ]; then icon=$i25
     else                          icon=$i0; fi ;;
esac

class="good"
[ "$cap" -le 30 ] && class="warning"
[ "$cap" -le 15 ] && class="critical"
[ "$status" = "Charging" ] && class="charging"

ac=$(cat /sys/class/power_supply/A{C,DP}*/online 2>/dev/null | grep -m1 1)
case "$status" in
  Charging)       st="charging" ;;
  Discharging)    st="on battery" ;;
  Full)           st="full" ;;
  "Not charging") st="plugged in (holding)" ;;
  *)              st=$([ -n "$ac" ] && echo "plugged in" || printf '%s' "$status" | tr 'A-Z' 'a-z') ;;
esac
text="<span font_family='Font Awesome 6 Free' weight='heavy'>${icon}</span>  ${cap}%"
tip="${cap}%  ┬Ę  ${st}  ┬Ę  ${health}% health  ┬Ę  ${cyc:-?} cycles  ┬Ę  Profile: ${prof}"
printf '{"text":"%s","tooltip":"%s","class":"%s","percentage":%s}\n' "$text" "$tip" "$class" "$cap"
