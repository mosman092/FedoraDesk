#!/usr/bin/env bash
# read clipboard from stdin (wl-paste --watch); never call wl-paste here (deadlock)
set -u
dir="$HOME/.cache/clip-history"
mkdir -p "$dir"

tmp=$(mktemp)
cat > "$tmp"
[ -s "$tmp" ] || { rm -f "$tmp"; exit 0; }

magic=$(head -c4 "$tmp" | od -An -tx1 | tr -d ' \n')
if [ "$magic" = "89504e47" ]; then
  id=$(cksum "$tmp" | cut -d' ' -f1)
  mv -f "$tmp" "$dir/img_$id.png"; touch "$dir/img_$id.png"
else
  content=$(cat "$tmp"); rm -f "$tmp"
  [ -z "${content//[$' \t\n']/}" ] && exit 0
  id=$(printf '%s' "$content" | cksum | tr -d ' ')
  printf '%s' "$content" > "$dir/txt_$id"; touch "$dir/txt_$id"
fi

ls -1t "$dir" 2>/dev/null | tail -n +201 | while read -r f; do rm -f "$dir/$f"; done
